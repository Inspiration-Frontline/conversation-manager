<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ifl.agentbreaker.conversationmanager.dao.ConversationLlmRequestMessageMapper">
    <resultMap id="RequestMessageResultMap" type="ifl.agentbreaker.conversationmanager.domain.entities.pg.ConversationLlmRequestMessage">
        <id column="id" property="id"/>
        <result column="creator_id" property="creatorId"/>
        <result column="creation_time" property="creationTime"/>
        <result column="modifier_id" property="modifierId"/>
        <result column="modification_time" property="modificationTime"/>
        <result column="llm_call_id" property="llmCallId"/>
        <result column="message_order" property="messageOrder"/>
        <result column="role" property="role"/>
        <result column="content" property="content"/>
        <result column="content_parts" property="contentParts"/>
        <result column="tool_call_id" property="toolCallId"/>
    </resultMap>

    <select id="insertRequestMessage" resultMap="RequestMessageResultMap" affectData="true">
        INSERT INTO "conversation_llm_request_message" (
            "creator_id", "modifier_id", "llm_call_id", "message_order", "role", "content",
            "content_parts", "tool_call_id"
        ) VALUES (
            #{creatorId}, #{modifierId}, #{llmCallId}, #{messageOrder}, #{role}, #{content},
            CAST(#{contentParts} AS JSONB), #{toolCallId}
        )
        RETURNING *
    </select>
</mapper>
