<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ifl.agentbreaker.conversationmanager.dao.ConversationLlmToolDefinitionMapper">
    <resultMap id="ToolDefinitionResultMap" type="ifl.agentbreaker.conversationmanager.domain.entities.pg.ConversationLlmToolDefinition">
        <id column="id" property="id"/>
        <result column="creator_id" property="creatorId"/>
        <result column="creation_time" property="creationTime"/>
        <result column="modifier_id" property="modifierId"/>
        <result column="modification_time" property="modificationTime"/>
        <result column="llm_call_id" property="llmCallId"/>
        <result column="tool_order" property="toolOrder"/>
        <result column="tool_key" property="toolKey"/>
        <result column="tool_name" property="toolName"/>
        <result column="source_type" property="sourceType"/>
        <result column="description" property="description"/>
        <result column="parameters_json" property="parametersJson"/>
        <result column="strict" property="strict"/>
        <result column="definition_hash" property="definitionHash"/>
    </resultMap>

    <insert id="insertToolDefinitions">
        INSERT INTO "conversation_llm_tool_definition" (
            "creator_id", "modifier_id", "llm_call_id", "tool_order", "tool_key", "tool_name",
            "source_type", "description", "parameters_json", "strict", "definition_hash"
        ) VALUES
        <foreach collection="items" item="item" separator=",">
            (
                #{item.creatorId}, #{item.modifierId}, #{item.llmCallId}, #{item.toolOrder},
                #{item.toolKey}, #{item.toolName}, #{item.sourceType}, #{item.description},
                #{item.parametersJson}, #{item.strict}, #{item.definitionHash}
            )
        </foreach>
    </insert>
</mapper>
